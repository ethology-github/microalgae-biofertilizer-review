{
  "test_cases": [
    {
      "id": "tc-001",
      "stage": "phase1_aminer",
      "description": "AMiner API调用成功返回文献列表",
      "input": {
        "query": "microalgae biofertilizer nitrogen fixation",
        "source": "aminer",
        "max_results": 50
      },
      "expected": {
        "status": "success",
        "returns": "list",
        "has_results": true,
        "result_count": "> 0"
      }
    },
    {
      "id": "tc-002",
      "stage": "phase1_pubmed",
      "description": "PubMed API调用成功返回文献列表",
      "input": {
        "query": "microalgae biofertilizer nitrogen fixation",
        "source": "pubmed",
        "max_results": 50
      },
      "expected": {
        "status": "success",
        "returns": "list",
        "has_results": true,
        "result_count": "> 0"
      }
    },
    {
      "id": "tc-003",
      "stage": "phase1_empty_result",
