      "input": {
        "query": "xyznonexistentquery12345",
        "source": "aminer",
        "max_results": 50
      },
      "expected": {
        "status": "success",
        "returns": "list",
        "has_results": false,
        "result_count": 0,
        "handles_gracefully": true
      }
    },
    {
      "id": "tc-004",
      "stage": "phase2_doi_dedup",
      "description": "基于DOI的精确去重",
      "input": {
        "papers": [
          {"doi": "10.1234/test1", "title": "Paper A"},
          {"doi": "10.1234/test1", "title": "Paper A (duplicate)"},
          {"doi": "10.1234/test2", "title": "Paper B"}
        ]
      },
      "expected": {
        "deduplicated_count": 2,
        "removed_duplicates": 1,
        "duplicates_identified_by": "doi"
      }
    },
    {
      "id": "tc-005",
      "stage": "phase2_title_similarity",
      "description": "标题相似度去重(85%阈值)",
      "input": {
        "papers": [
          {"doi": "10.1234/test1", "title": "Effect of Microalgae on Plant Growth"},
          {"doi": "10.1234/test2", "title": "Effect of Microalgae on Plant Growth and Development"},
          {"doi": "10.1234/test3", "title": "Completely Different Study on Soil"}
        ]
      },
      "expected": {
        "similar_pairs_flagged": 1,
        "similarity_threshold": 0.85,
        "similarity_method": "title_similarity"
      }
    },
    {
      "id": "tc-006",
      "stage": "phase2_merge_databases",
      "description": "多数据库合并去重",
      "input": {
        "aminer_results": [
          {"doi": "10.1234/a1", "title": "Study A"},
          {"doi": "10.1234/a2", "title": "Study B"}
        ],
        "pubmed_results": [
          {"doi": "10.1234/a1", "title": "Study A"},
          {"doi": "10.1234/p1", "title": "Study from PubMed"}
        ]
      },
      "expected": {
        "total_unique": 3,
        "aminer_count": 2,
        "pubmed_count": 2,
        "merged_deduplicated": 3
      }
    },
    {
      "id": "tc-007",
      "stage": "phase3_title_include",
      "description": "标题关键词匹配-通过筛选",
      "input": {
        "title": "Microalgae as Biofertilizer for Nitrogen Fixation in Rice",
        "keywords": ["microalgae", "biofertilizer", "nitrogen fixation"]
      },
      "expected": {
        "decision": "include",
        "matched_keywords": ["microalgae", "biofertilizer", "nitrogen fixation"],
        "match_score": 3
      }
    },
    {
      "id": "tc-008",
      "stage": "phase3_title_exclude",
      "description": "标题关键词匹配-排除筛选",
      "input": {
        "title": "Effect of Chemical Fertilizers on Algae Growth",
        "include_keywords": ["microalgae", "biofertilizer"],
        "exclude_keywords": ["chemical fertilizer", "pesticide"]
      },
      "expected": {
        "decision": "exclude",
        "reason": "exclude_keyword_match",
        "matched_exclude": ["chemical fertilizer"]
      }
    },
    {
      "id": "tc-009",
      "stage": "phase3_abstract_filter",
      "description": "摘要内容筛选验证相关性",
      "input": {
        "abstract": "This study investigates the use of Chlorella vulgaris for biological nitrogen fixation in agricultural soils. Results show a 40% increase in soil nitrogen content.",
        "required_concepts": ["microalgae", "nitrogen fixation", "agricultural"]
      },
      "expected": {
        "passes_filter": true,
        "concepts_found": ["microalgae", "nitrogen fixation", "agricultural"],
        "concepts_missing": []
      }
    },
    {
      "id": "tc-010",
      "stage": "phase3_mechanism_classification",
      "description": "机制分类-M1固氮",
